<launch>
  <arg name="world" default="test_scenario3.1.world"/>
  <arg name="task" default="task3"/>
  <arg name="task_delay" default="10"/>

  <set_env name="GAZEBO_MODEL_PATH" value="$(env GAZEBO_MODEL_PATH):$(find-pkg-share krr_gazebo)/models"/>

  <include file="$(find-pkg-share mirte_gazebo)/launch/gazebo_mirte_master_navigation.launch.py">
    <arg name="world" value="$(find-pkg-share krr_gazebo)/worlds/$(var world)"/>
  </include>

  <include file="$(find-pkg-share krr_mirte_skills)/launch/mirte_skills.launch.xml"/>

  <node pkg="krr_agent" exec="krr_agent" name="krr_agent">
    <param name="task" value="$(var task)" />
    <param name="task_delay" value="$(var task_delay)" />
  </node>
</launch>
